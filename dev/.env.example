SFTP_HOST=example.com
SFTP_PORT=22
SFTP_USER=username
SFTP_PRIVATE_KEY=C:\Users\your-user\.ssh\id_ed25519
SFTP_PASSPHRASE=
# SFTP_PASSWORD=password
SFTP_REMOTE_DEV_DIR=/home/username/public_html/dev

# Recommended. Compare with: ssh-keygen -lf <known_hosts entry>
# SFTP_HOST_FINGERPRINT=SHA256:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
